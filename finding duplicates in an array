#include <stdio.h>

int main()
{
    int a[20], i, j = 0, n, count = 0;

    printf("enter the size of array");
    scanf("%d", &n);

    printf("enter the array elements");
    for (i = 0; i < n; i++)
    {
        scanf("%d", &a[i]);
    }

    for (i = 0; i < n; i++)
    {
        for (j = i + 1; j < n; j++)
        {
            if (a[i] == a[j])
            {
                printf("%d is duplicated", a[i]);
                count++;
                break;
            }
        }
    }

    if (count == 0)
    {
        printf("not duplicated");
    }

    return 0;
}
