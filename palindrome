#include<stdio.h>

int main()
{
    int x, original, reverse = 0, rem;
    
    printf("enter a number:");
    scanf("%d", &x);
    
    original = x;
    
    while(x != 0)
    {
        rem = x % 10;
        reverse = reverse * 10 + rem;
        x = x / 10;
    }
    
    if(original == reverse)
    {
        printf("%d is a pallindrome", original);
    }
    else
    {
        printf("%d is not a pallindrome", original);
    }
    
    return 0;
}
