#include <stdio.h>

int main()
{
    int num, digit, original, sum = 0;
    
    printf("enter a number:");
    scanf("%d", &num);
    
    original = num;
    
    while (num >= 10)
    {
        sum = 0;
        while (num != 0)
        {
            digit = num % 10;
            sum = sum + digit;
            num = num / 10;
        }
        num = sum;
    }
    
    printf("last digit after summatiom of %d digits is %d", original, num);
    
    return 0;
}
